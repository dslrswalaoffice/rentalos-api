# ============================================================================
# RentalOS · Environment
# ============================================================================
# Copy this file to .env and fill in real values. Never commit .env.

# --- Database (required) ----------------------------------------------------
# Neon connection string. Get it from the Neon dashboard → your project → Connection Details.
# Prefer the pooled connection URL (ends with -pooler.<region>.neon.tech).
DATABASE_URL=postgres://user:pass@host.neon.tech/rentalos?sslmode=require

# --- App ---------------------------------------------------------------------
# 'development' disables Secure-cookie flag (needed for http://localhost)
NODE_ENV=development

# Public origin for building reset-password links in emails.
# Local dev: http://localhost:3000  |  Prod: https://rms.dslrswala.com
APP_ORIGIN=http://localhost:3000

# --- Sessions ---------------------------------------------------------------
# TTL for sessions (browser cookie + DB row). Sliding window on activity.
SESSION_TTL_DAYS=30

# TTL for password reset links.
PASSWORD_RESET_TTL_MINUTES=30

# --- Rate limits ------------------------------------------------------------
# Login: max failures per email/IP per 15 min before we start returning 429.
LOGIN_MAX_FAILURES_PER_EMAIL=5
LOGIN_MAX_FAILURES_PER_IP=20

# Password reset: max requests per email per hour.
PASSWORD_RESET_MAX_PER_HOUR=3

# --- Seed (used by the /api/admin/seed bootstrap endpoint) ------------------
# The owner's initial password. CHANGE IT after first login.
# You can also just re-run seed with a different value.
SEED_OWNER_EMAIL=aamir@dslrswala.com
SEED_OWNER_NAME=Aamir Patel
SEED_OWNER_PASSWORD=change-me-on-first-login

# --- Admin bootstrap --------------------------------------------------------
# Gates the /api/admin/migrate and /api/admin/seed endpoints. Unset = disabled (503).
ADMIN_SETUP_TOKEN=
# Delete this env var from Vercel after initial setup — see README.md
